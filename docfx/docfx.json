{
  "metadata": [
    {
      "src": [
        { "src": "../src/main", "files": [ "**/*.csproj" ] }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": { "TargetFramework": "net48", "Configuration": "Release" }
    }
  ],
  "build": {
    "content": [
      { "files": [ "api/**.yml", "api/index.md" ] },
      { "files": [ "articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md" ] }
    ],
    "resource": [
      { "files": [ "images/**", "template/**" ] }
    ],
    "output": "_site",
    "template": [ "default", "modern", "template" ],
    "globalMetadata": {
      "_appName": "Thunder",
      "_appTitle": "Thunder — utilitários .NET para o dia a dia brasileiro",
      "_appLogoPath": "images/thunder.png",
      "_appFaviconPath": "images/thunder.png",
      "_enableSearch": true,
      "_disableContribution": true,
      "_appFooter": "Thunder · MIT · <a href=\"https://www.nuget.org/profiles/acaldeira\">NuGet</a>"
    }
  }
}
