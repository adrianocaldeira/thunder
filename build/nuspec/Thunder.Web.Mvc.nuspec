<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Thunder.Web.Mvc</id>
    <version>1.9.0</version>
    <title>Thunder.Web.Mvc</title>
    <authors>Adriano Caldeira</authors>
    <owners>acaldeira.dev</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/adrianocaldeira/thunder</projectUrl>
    <iconUrl>https://github.com/adrianocaldeira/thunder/raw/master/thunder.png</iconUrl>
    <description>HTML helpers, filtros e model binders para ASP.NET MVC 5, integrados ao Thunder.</description>
    <releaseNotes>Correções de segurança: model binder decimal robusto, codificação de mensagens (XSS), validação de callback JSONP e host canônico configurável. Consulte o CHANGELOG: https://github.com/adrianocaldeira/thunder/blob/master/CHANGELOG.md</releaseNotes>
    <copyright>Copyright © Adriano Caldeira</copyright>
    <tags>aspnet mvc htmlhelpers modelbinder net48</tags>
    <dependencies>
      <dependency id="Thunder" version="1.10.0" />
      <dependency id="Microsoft.AspNet.Mvc" version="5.3.0" />
    </dependencies>
  </metadata>
  <files>
    <file src="src\main\Thunder.Web.Mvc\bin\Release\Thunder.Web.Mvc.dll" target="lib\net48" />
    <file src="src\main\Thunder.Web.Mvc\bin\Release\Thunder.Web.Mvc.pdb" target="lib\net48" />
    <file src="src\main\Thunder.Web.Mvc\bin\Release\Thunder.Web.Mvc.xml" target="lib\net48" />
  </files>
</package>
